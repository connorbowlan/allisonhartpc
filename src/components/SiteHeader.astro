---
import { createBasePath } from '../lib/paths';

interface Props {
  activePage: 'home' | 'profile' | 'practice' | 'contact';
}

const { activePage } = Astro.props;
const withBase = createBasePath(import.meta.env.BASE_URL);
---

<header>
  <div id="top">
    <div id="top-center">
      <div class="social">
        <br />
      </div>
      <nav>
        <ul>
          <li><a href={withBase('/')} class={activePage === 'home' ? 'active' : undefined}>Home</a></li>
          <li><a href={withBase('/profile')} class={activePage === 'profile' ? 'active' : undefined}>Profile</a></li>
          <li><a href={withBase('/practice')} class={activePage === 'practice' ? 'active' : undefined}>Practice</a></li>
          <li><a href={withBase('/contact')} class={activePage === 'contact' ? 'active' : undefined}>Contact</a></li>
          <li class="nav-aside-link">
            <a href="https://secure.lawpay.com/pages/allisonhart/operating/" target="_blank" rel="noopener noreferrer">Pay Online</a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
  <div id="skyline" style={`background-image: url('${withBase('/images/skyline.jpg')}')`}>
    <a href={withBase('/')}>Allison Hart</a>
    <span class="tagline">Attorney at Law</span>
  </div>
</header>
