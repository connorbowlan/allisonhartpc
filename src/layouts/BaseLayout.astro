---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { createBasePath } from '../lib/paths';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activePage: 'home' | 'profile' | 'practice' | 'contact';
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, activePage, structuredData } = Astro.props;
const withBase = createBasePath(import.meta.env.BASE_URL);

const siteUrl = Astro.site ?? new URL('https://connorbowlan.github.io');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const pageTitle = `${title} | Allison Hart, P.C. | Oklahoma City Attorney`;
const pageDescription =
  description ??
  'Allison Hart provides experienced, practical legal representation in Oklahoma City, including family law, child custody, child support, DUI defense, wills, trusts, and civil matters.';
const socialImageUrl = new URL(withBase('/images/skyline.jpg'), siteUrl).toString();
const organizationUrl = new URL(withBase('/'), siteUrl).toString();
const attorneySchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Attorney',
  name: 'Allison Hart, P.C.',
  url: organizationUrl,
  image: socialImageUrl,
  telephone: '+1-405-340-6340',
  email: 'allison@hartlawfirm.org',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '701 NW 13th Street',
    addressLocality: 'Oklahoma City',
    addressRegion: 'OK',
    postalCode: '73103',
    addressCountry: 'US',
  },
  areaServed: [
    'Oklahoma City',
    'Edmond',
    'Moore',
    'Norman',
    'Guthrie',
    'Stillwater',
    'Shawnee',
  ],
  sameAs: [
    'https://www.expertise.com/ok/oklahoma-city/child-support-lawyers',
    'https://www.msn.com/en-us/news/other/top-lawyers-setting-new-precedents-in-the-legal-industry/ar-AA21VHjP',
  ],
};
const pageStructuredData = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const structuredDataItems = [attorneySchema, ...pageStructuredData];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="description" content={pageDescription} />
    <meta
      name="keywords"
      content="attorney, legal, case, felony, divorce, misdemeanor, oklahoma county, logan county, lawyer, law, child support, paternity, modification, will, testament, oklahoma"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <meta name="msvalidate.01" content="1BA556BBE6309C2F830D503BA98E92C1" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Allison Hart, P.C." />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImageUrl} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />

    <link rel="apple-touch-icon" sizes="57x57" href={withBase('/images/favicons/apple-touch-icon-57x57.png')} />
    <link rel="apple-touch-icon" sizes="60x60" href={withBase('/images/favicons/apple-touch-icon-60x60.png')} />
    <link rel="apple-touch-icon" sizes="72x72" href={withBase('/images/favicons/apple-touch-icon-72x72.png')} />
    <link rel="apple-touch-icon" sizes="76x76" href={withBase('/images/favicons/apple-touch-icon-76x76.png')} />
    <link rel="apple-touch-icon" sizes="114x114" href={withBase('/images/favicons/apple-touch-icon-114x114.png')} />
    <link rel="apple-touch-icon" sizes="120x120" href={withBase('/images/favicons/apple-touch-icon-120x120.png')} />
    <link rel="apple-touch-icon" sizes="144x144" href={withBase('/images/favicons/apple-touch-icon-144x144.png')} />
    <link rel="apple-touch-icon" sizes="152x152" href={withBase('/images/favicons/apple-touch-icon-152x152.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase('/images/favicons/apple-touch-icon-180x180.png')} />
    <link rel="icon" type="image/png" href={withBase('/images/favicons/favicon-32x32.png')} sizes="32x32" />
    <link rel="icon" type="image/png" href={withBase('/images/favicons/android-chrome-192x192.png')} sizes="192x192" />
    <link rel="icon" type="image/png" href={withBase('/images/favicons/favicon-96x96.png')} sizes="96x96" />
    <link rel="icon" type="image/png" href={withBase('/images/favicons/favicon-16x16.png')} sizes="16x16" />
    <link rel="manifest" href={withBase('/images/favicons/manifest.json')} />
    <link rel="shortcut icon" href={withBase('/images/favicons/favicon.ico')} />
    <meta name="msapplication-TileColor" content="#da532c" />
    <meta name="msapplication-TileImage" content={withBase('/images/favicons/mstile-144x144.png')} />
    <meta name="msapplication-config" content={withBase('/images/favicons/browserconfig.xml')} />
    <link rel="preload" as="image" href={withBase('/images/skyline.jpg')} fetchpriority="high" />
    {
      structuredDataItems.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }

    <script async src="https://www.google-analytics.com/analytics.js"></script>
    <script is:inline>
      window.ga =
        window.ga ||
        function () {
          // @ts-ignore legacy GA queue
          (ga.q = ga.q || []).push(arguments);
        };
      // @ts-ignore
      ga.l = +new Date();
      // @ts-ignore
      ga('create', 'UA-63671816-1', 'auto');
      // @ts-ignore
      ga('send', 'pageview');
    </script>
    <script src="https://kit.fontawesome.com/c859dfc8f4.js" crossorigin="anonymous"></script>
  </head>
  <body>
    <SiteHeader activePage={activePage} />
    <main class="site-main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
