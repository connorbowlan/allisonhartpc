---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createBasePath } from '../lib/paths';

const withBase = createBasePath(import.meta.env.BASE_URL);
---

<BaseLayout
  title="Practice"
  description="Review Oklahoma City legal services from Allison Hart, P.C., including family law, child custody, child support, criminal defense, and related civil matters."
  activePage="practice"
>
  <div class="content">
    <h1 class="heading-with-icon"><i class="fa fa-info-circle heading-icon" aria-hidden="true"></i><span>Practice</span></h1>
    <p>Allison Hart, P.C. provides legal representation in Oklahoma City with a focus on family law and practical case strategy. As experience broadened, the firm expanded to support clients across multiple legal areas while keeping client communication clear and responsive.</p>
    <p>Allison Hart has represented clients in Oklahoma City, Edmond, Moore, Norman, El Reno, Guthrie, Stillwater, Shawnee, and other communities across Oklahoma. To review attorney background and credentials, visit the <a href={withBase('/profile')}>Profile</a> page.</p>
    <p><strong>If you are involved in or interested in pursuing a legal case, please review the list of areas she currently practices below:</strong></p>
    <h1 class="heading-with-icon"><i class="fa fa-gavel heading-icon" aria-hidden="true"></i><span>Practice Areas</span></h1>
  </div>
  <div class="columns">
    <div class="column-1">
      <h2 class="subheading-with-icon"><i class="fa fa-users section-icon" aria-hidden="true"></i><span>Family Law</span></h2>
      <ul>
        <li>Divorce</li>
        <li>Paternity</li>
        <li>Child Custody</li>
        <li>Visitation</li>
        <li>Child Support Guidelines</li>
        <li>Grandparents Rights</li>
      </ul>
      <h2 class="subheading-with-icon"><i class="fa fa-heart section-icon" aria-hidden="true"></i><span>Adoption</span></h2>
      <ul>
        <li>Step-parent Adoption</li>
        <li>Termination of Parental Rights</li>
      </ul>
    </div>
    <div class="column-2">
      <h2 class="subheading-with-icon"><i class="fa fa-balance-scale section-icon" aria-hidden="true"></i><span>Criminal</span></h2>
      <ul>
        <li>Driving Under the Influence</li>
        <li>Driving While Intoxicated</li>
        <li>Public Intoxication</li>
        <li>Possession</li>
        <li>Probation Revocations</li>
      </ul>
    </div>
    <div class="column-3">
      <h2 class="subheading-with-icon"><i class="fa fa-briefcase section-icon" aria-hidden="true"></i><span>Others/Misc.</span></h2>
      <ul>
        <li>Personal Injury</li>
        <li>Wrongful Termination</li>
        <li>Foreclosures</li>
      </ul>
    </div>
  </div>
</BaseLayout>
