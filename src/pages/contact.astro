---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createBasePath } from '../lib/paths';

const withBase = createBasePath(import.meta.env.BASE_URL);
const siteUrl = Astro.site ?? new URL('https://connorbowlan.github.io');
const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Allison Hart, P.C.',
  url: new URL(withBase('/contact'), siteUrl).toString(),
  about: {
    '@type': 'Attorney',
    name: 'Allison Hart, P.C.',
  },
};
---

<BaseLayout
  title="Contact"
  description="Contact Allison Hart, P.C. in Oklahoma City by phone or email to discuss family law, child custody, criminal defense, estate planning, or other legal matters."
  activePage="contact"
  structuredData={contactPageSchema}
>
  <div class="content contact-intro">
    <h1 class="heading-with-icon"><i class="fa fa-phone heading-icon" aria-hidden="true"></i><span>Contact</span></h1>
    <p>If you need legal help in Oklahoma City or surrounding communities, the fastest way to connect is by phone or direct email. You can use the map for directions, review office details, and then send a message below. For services, visit <a href={withBase('/practice')}>Practice Areas</a>.</p>
  </div>

  <div class="columns contact-grid">
    <section class="column-1 contact-panel contact-panel-map">
      <h1 class="heading-with-icon"><i class="fa fa-map-marker heading-icon" aria-hidden="true"></i><span>Map</span></h1>
      <div class="map-frame">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d12995.531761289427!2d-97.524262!3d35.48244!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0xe66b4e4bdbbe6517!2sHart+Law+Firm!5e0!3m2!1sen!2sus!4v1433278822979"
          class="map-embed"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Hart Law Firm map"
        ></iframe>
      </div>
      <p class="map-note"><a class="contact-link-button" href="https://maps.google.com/?q=701+NW+13th+Street,+Oklahoma+City,+OK+73103" target="_blank" rel="noopener noreferrer">Open Directions in Google Maps</a></p>
    </section>
    <section class="column-2 contact-panel contact-panel-office">
      <h1 class="heading-with-icon"><i class="fa fa-info-circle heading-icon" aria-hidden="true"></i><span>Office Information</span></h1>
      <h2 class="office-address">701 NW 13th Street<br />Oklahoma City, OK 73103</h2>
      <ul class="contact-details">
        <li><i class="fa fa-phone inline-icon" aria-hidden="true"></i> Phone: <a href="tel:4053406340">(405) 340-6340</a></li>
        <li><i class="fa fa-fax inline-icon" aria-hidden="true"></i> Fax: (405) 604-9054</li>
        <li><i class="fa fa-envelope inline-icon" aria-hidden="true"></i> Email: <a href="mailto:allison@hartlawfirm.org">allison@hartlawfirm.org</a></li>
      </ul>
      <p class="office-service-area">Serving Oklahoma City and surrounding communities, including Edmond, Moore, Norman, Guthrie, Stillwater, and Shawnee.</p>
    </section>
  </div>

  <section class="content contact-form-section">
    <h1 class="heading-with-icon"><i class="fa fa-envelope heading-icon" aria-hidden="true"></i><span>Send a Message</span></h1>
    <form id="contact-form" class="contact-form" novalidate>
      <p class="contact-form-meta"><span class="required">*</span> Required fields</p>
      <div class="contact-form-grid">
        <div class="contact-form-field">
          <label for="firstName">First Name <span class="required">*</span></label>
          <input id="firstName" name="firstName" type="text" maxlength="255" autocomplete="given-name" placeholder="First name" required />
        </div>
        <div class="contact-form-field">
          <label for="lastName">Last Name <span class="required">*</span></label>
          <input id="lastName" name="lastName" type="text" maxlength="255" autocomplete="family-name" placeholder="Last name" required />
        </div>
        <div class="contact-form-field">
          <label for="email">Email Address <span class="required">*</span></label>
          <input id="email" name="email" type="email" maxlength="255" autocomplete="email" placeholder="you@example.com" required />
        </div>
        <div class="contact-form-field">
          <label for="phone">Phone Number</label>
          <input id="phone" name="phone" type="tel" maxlength="14" inputmode="tel" placeholder="(405) 123-4567" autocomplete="tel" />
        </div>
        <div class="contact-form-field">
          <label for="referral">How did you find us?</label>
          <input id="referral" name="referral" type="text" maxlength="255" placeholder="Referral, search, etc." />
        </div>
        <div class="contact-form-field">
          <label for="county">What county has jurisdiction on your case?</label>
          <input id="county" name="county" type="text" maxlength="255" placeholder="e.g., Oklahoma County" />
        </div>
        <div class="contact-form-field contact-form-field-full">
          <label for="message">Briefly describe how we can help <span class="required">*</span></label>
          <textarea id="message" name="message" minlength="10" placeholder="Share a brief summary of your legal matter." required></textarea>
        </div>
      </div>
      <div class="contact-form-actions">
        <button type="submit"><i class="fa fa-paper-plane" aria-hidden="true"></i><span>Send Message</span></button>
      </div>
      <p id="contact-form-status" class="contact-form-status" aria-live="polite"></p>
      <noscript>
        <p class="contact-form-status">JavaScript is required to open the email draft. You can email us directly at <a href="mailto:allison@hartlawfirm.org">allison@hartlawfirm.org</a>.</p>
      </noscript>
    </form>
  </section>

  <script is:inline>
    const contactForm = document.getElementById('contact-form');
    const statusEl = document.getElementById('contact-form-status');
    if (contactForm instanceof HTMLFormElement && statusEl instanceof HTMLElement) {
      contactForm.addEventListener('submit', (event) => {
        event.preventDefault();
        statusEl.classList.remove('is-error', 'is-success');
        if (!contactForm.reportValidity()) {
          statusEl.classList.add('is-error');
          statusEl.textContent = 'Please fill in the required fields.';
          return;
        }

        const formData = new FormData(contactForm);
        const firstName = String(formData.get('firstName') ?? '').trim();
        const lastName = String(formData.get('lastName') ?? '').trim();
        const email = String(formData.get('email') ?? '').trim();
        const phone = String(formData.get('phone') ?? '').trim();
        const referral = String(formData.get('referral') ?? '').trim();
        const county = String(formData.get('county') ?? '').trim();
        const message = String(formData.get('message') ?? '').trim();

        const bodyLines = [
          `First Name: ${firstName}`,
          `Last Name: ${lastName}`,
          `Email: ${email}`,
          `Phone: ${phone || 'Not provided'}`,
          `Referral: ${referral || 'Not provided'}`,
          `County: ${county || 'Not provided'}`,
          '',
          'Message:',
          message,
        ];
        const subject = `Website Contact - ${firstName} ${lastName}`.trim();
        const mailtoLink = `mailto:allison@hartlawfirm.org?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(bodyLines.join('\n'))}`;

        statusEl.classList.add('is-success');
        statusEl.textContent = 'Opening your email app with this message draft...';
        window.location.href = mailtoLink;
      });
    }
  </script>
</BaseLayout>
